{
  "name": "f.e.r.r.o",
  "version": "1.0.0",
  "description": "F.E.R.R.O — Ferramenta Estratégica de Resposta em Rift Online",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "author": "Mickael - Fortech Digital",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "electron-vite": "^5.0.0",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "say": "^0.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  },
  "build": {
    "appId": "com.mickael.fortech.ferro",
    "productName": "F.E.R.R.O",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "icon": "resources/icon.png",
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
